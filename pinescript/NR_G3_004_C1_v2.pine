//@version=5
strategy("NR-G3-004-C1 | News Reaction Breakout", 
     overlay=true, 
     initial_capital=100000, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=4.50,
     slippage=2,
     process_orders_on_close=false,
     calc_on_every_tick=false)

// ── Parameters ──────────────────────────────────────────────
atr_mult    = input.float(1.3,  "ATR Burst Multiplier", step=0.1)
vol_mult    = input.float(1.5,  "Volume Multiplier", step=0.1)
atr_len     = input.int(14,     "ATR Period")
atr_avg_len = input.int(20,     "ATR Average Period")
vol_avg_len = input.int(20,     "Volume Average Period")
mom_len     = input.int(3,      "Momentum Lookback")
min_hold    = input.int(2,      "Min Hold Bars", minval=1)
max_hold    = input.int(20,     "Max Hold Bars (0=disabled)", minval=0)

// Optional: BB compression filter
use_bb_filter = input.bool(true, "Use BB Compression Filter")
bb_len      = input.int(20,     "BB Period")
bb_std      = input.float(2.0,  "BB Std Dev")
bb_pct_max  = input.float(15.0, "BB Width Percentile Max")
bb_rank_len = input.int(252,    "BB Rank Lookback")

// ── Indicators ──────────────────────────────────────────────
_atr = ta.atr(atr_len)
atr_avg = ta.sma(_atr, atr_avg_len)
atr_burst = _atr > atr_avg * atr_mult

vol_avg = ta.sma(volume, vol_avg_len)
vol_spike = volume > vol_avg * vol_mult

burst = atr_burst and vol_spike

[bb_mid, bb_hi, bb_lo] = ta.bb(close, bb_len, bb_std)
bb_width = (bb_hi - bb_lo) / bb_mid
bb_width_rank = ta.percentrank(bb_width, bb_rank_len)
compression = bb_width_rank <= bb_pct_max

burst_or_compress = burst or (use_bb_filter and compression and volume > vol_avg * math.max(1.0, vol_mult * 0.6))

momentum = close - close[mom_len]

// ── Entry Signals ───────────────────────────────────────────
long_signal  = burst_or_compress and momentum > 0
short_signal = burst_or_compress and momentum < 0

// ── Position Tracking ───────────────────────────────────────
var int bars_in_trade = 0
var int trade_dir = 0  // 1=long, -1=short, 0=flat

if strategy.position_size > 0
    if trade_dir != 1
        bars_in_trade := 0
    trade_dir := 1
    bars_in_trade += 1
else if strategy.position_size < 0
    if trade_dir != -1
        bars_in_trade := 0
    trade_dir := -1
    bars_in_trade += 1
else
    trade_dir := 0
    bars_in_trade := 0

// ── Exit Conditions (only after min hold) ───────────────────
can_exit = bars_in_trade >= min_hold

// Momentum reversal exit
mom_exit_long  = momentum <= 0
mom_exit_short = momentum >= 0

// Max hold exit
max_hold_exit = max_hold > 0 and bars_in_trade >= max_hold

// ── Execute Orders ──────────────────────────────────────────
// Entry: only when flat
if long_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

if short_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)

// Exit: only after minimum hold period
if strategy.position_size > 0 and can_exit and (mom_exit_long or max_hold_exit)
    strategy.close("Long", comment=max_hold_exit ? "MaxHold" : "MomExit")

if strategy.position_size < 0 and can_exit and (mom_exit_short or max_hold_exit)
    strategy.close("Short", comment=max_hold_exit ? "MaxHold" : "MomExit")

// ── Visuals ─────────────────────────────────────────────────
bgcolor(burst ? color.new(color.red, 90) : na, title="ATR Burst")
bgcolor(compression and use_bb_filter ? color.new(color.blue, 95) : na, title="BB Compression")
plotshape(long_signal and strategy.position_size == 0, "Long", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(short_signal and strategy.position_size == 0, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
