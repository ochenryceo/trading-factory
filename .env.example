# Trading Factory Environment Configuration
POSTGRES_USER=factory
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=trading_factory
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://factory:your_password_here@localhost:5432/trading_factory
DATABASE_URL_SYNC=postgresql://factory:your_password_here@localhost:5432/trading_factory

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

DATABENTO_API_KEY=your_databento_key_here

# Webhook secrets
WEBHOOK_SECRET=your_webhook_secret
NINJA_SECRET=your_ninja_secret

# Discord channels (for alert routing)
DISCORD_CEO_CHANNEL=your_channel_id
DISCORD_ALERTS_CHANNEL=your_channel_id
DISCORD_SYSTEM_CHANNEL=your_channel_id
DISCORD_PAPER_CHANNEL=your_channel_id

# App settings
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
